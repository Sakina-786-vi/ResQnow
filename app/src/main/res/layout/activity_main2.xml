<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="8dp">

            <!-- Status dot + label -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_red"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvTrackingStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ TRACKING OFF"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/rajdhani_medium"
                    tools:ignore="SmallSp"/>
            </LinearLayout>

            <!-- App title right-aligned -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="HIGHWAY SOS"
                android:textColor="@color/white_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="@font/rajdhani_bold"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <!-- ══ HERO EMERGENCY BUTTON ══ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginBottom="14dp">

                <!-- Pulse ring behind button -->
                <View
                    android:id="@+id/pulseRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/pulse_ring"
                    android:visibility="invisible"
                    android:layout_margin="4dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnEmergency"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@color/red_alert"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚨"
                            android:textSize="32sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMERGENCY"
                            android:textColor="@color/white_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:fontFamily="@font/rajdhani_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap → Full emergency protocol • Long press → Call 112 now"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- ══ QUICK ACTION ROW ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp"
                android:weightSum="3">

                <!-- Hospital -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCallHospital"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    app:cardBackgroundColor="@color/card_blue"
                    app:cardCornerRadius="16dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏥" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hospital" android:textColor="@color/white_primary"
                            android:textSize="12sp" android:fontFamily="@font/rajdhani_semibold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Police -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCallPolice"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    app:cardBackgroundColor="@color/card_blue"
                    app:cardCornerRadius="16dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👮" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Police 100" android:textColor="@color/white_primary"
                            android:textSize="12sp" android:fontFamily="@font/rajdhani_semibold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SOS SMS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnSendSms"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/card_orange"
                    app:cardCornerRadius="16dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📲" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SOS SMS" android:textColor="@color/white_primary"
                            android:textSize="12sp" android:fontFamily="@font/rajdhani_semibold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ══ GPS DASHBOARD CARD ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Section label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡  GPS LOCATION"
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp"
                        android:letterSpacing="0.18"
                        android:fontFamily="@font/rajdhani_semibold"
                        android:layout_marginBottom="14dp"/>

                    <!-- Lat / Lon row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="LATITUDE" android:textColor="@color/text_secondary"
                                android:textSize="9sp" android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tvLatitude" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="---.------°"
                                android:textColor="@color/white_primary" android:textSize="15sp"
                                android:fontFamily="monospace"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="LONGITUDE" android:textColor="@color/text_secondary"
                                android:textSize="9sp" android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tvLongitude" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="---.------°"
                                android:textColor="@color/white_primary" android:textSize="15sp"
                                android:fontFamily="monospace"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="14dp"/>

                    <!-- Highway / KM row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="HIGHWAY" android:textColor="@color/text_secondary"
                                android:textSize="9sp" android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tvHighwayName" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Detecting..."
                                android:textColor="@color/accent_cyan" android:textSize="22sp"
                                android:textStyle="bold" android:fontFamily="@font/rajdhani_bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="KM MARKER" android:textColor="@color/text_secondary"
                                android:textSize="9sp" android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tvKmMarker" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="KM ---"
                                android:textColor="@color/white_primary" android:textSize="22sp"
                                android:textStyle="bold" android:fontFamily="@font/rajdhani_bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Speed / Accuracy row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="SPEED" android:textColor="@color/text_secondary"
                                android:textSize="9sp" android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tvSpeedKmh" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--- km/h"
                                android:textColor="@color/white_primary" android:textSize="14sp"
                                android:fontFamily="monospace"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="ACCURACY" android:textColor="@color/text_secondary"
                                android:textSize="9sp" android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tvAccuracy" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="±--- m"
                                android:textColor="@color/white_primary" android:textSize="14sp"
                                android:fontFamily="monospace"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvLastUpdate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Updated: --:--"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ RUMOR DETECTION CARD ══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRumorStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍  RUMOR DETECTION"
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp"
                        android:letterSpacing="0.18"
                        android:fontFamily="@font/rajdhani_semibold"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <!-- Big vehicle counter -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="VEHICLES IN 500m ZONE"
                                android:textColor="@color/text_secondary" android:textSize="9sp"
                                android:letterSpacing="0.1"/>
                            <TextView android:id="@+id/tvVehicleCount"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/white_primary" android:textSize="42sp"
                                android:textStyle="bold" android:fontFamily="@font/rajdhani_bold"
                                android:lineSpacingMultiplier="0.9"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="phones / cars"
                                android:textColor="@color/text_secondary" android:textSize="10sp"/>
                        </LinearLayout>

                        <!-- Rumor icon -->
                        <ImageView
                            android:id="@+id/ivRumorIcon"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_radar"
                            app:tint="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Status text -->
                    <TextView
                        android:id="@+id/tvRumorStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Waiting for GPS data..."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/rajdhani_medium"
                        android:lineSpacingMultiplier="1.3"/>

                    <!-- Threshold hint -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3+ vehicles in zone → rumor debunked"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ NEAREST EMERGENCY ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍  NEAREST EMERGENCY"
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp"
                        android:letterSpacing="0.18"
                        android:fontFamily="@font/rajdhani_semibold"
                        android:layout_marginBottom="14dp"/>

                    <TextView
                        android:id="@+id/tvNearestHospital"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏥 Enable GPS to find nearest hospital"
                        android:textColor="@color/white_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvNearestPolice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="👮 Enable GPS to find nearest police"
                        android:textColor="@color/white_primary"
                        android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ QUICK TILE SETUP CARD ══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTileSetup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_highlight"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/accent_cyan"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡"
                        android:textSize="28sp"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Quick Settings Tile"
                            android:textColor="@color/accent_cyan"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/rajdhani_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Swipe down → tap → instant emergency. Tap here to learn how."
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:lineSpacingMultiplier="1.3"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/accent_cyan"
                        android:textSize="24sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ MAIN TRACKING BUTTON ══ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleTracking"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="▶  START TRACKING"
                android:textSize="15sp"
                android:letterSpacing="0.08"
                android:fontFamily="@font/rajdhani_bold"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/green_active"
                android:layout_marginBottom="10dp"/>

            <!-- ══ SHARE BUTTON ══ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareApp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="📤  Share via WhatsApp (10-sec install)"
                android:textSize="13sp"
                android:fontFamily="@font/rajdhani_medium"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="14dp"
                app:strokeColor="@color/divider"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
