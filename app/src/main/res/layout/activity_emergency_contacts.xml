<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Emergency Contacts (4)"
            android:textColor="@color/white_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add up to 4 contacts. When you trigger SOS, the app can send them your location via SMS."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:paddingBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/card_bg"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact 1 name"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/card_bg"
            android:layout_marginBottom="18dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact 1 phone"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/card_bg"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact 2 name"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/card_bg"
            android:layout_marginBottom="18dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact 2 phone"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/card_bg"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact 3 name"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/card_bg"
            android:layout_marginBottom="18dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact 3 phone"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/card_bg"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact 4 name"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/card_bg"
            android:layout_marginBottom="22dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact 4 phone"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveContacts"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Contacts"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/red_alert" />

    </LinearLayout>
</ScrollView>
